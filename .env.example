# LLM API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
PERPLEXITY_API_KEY=pplx-your-perplexity-key-here
GOOGLE_API_KEY=your-google-key-here
XAI_API_KEY=your-xai-api-key-here

# Optional: Model configurations
OPENAI_MODEL=gpt-5.2
ANTHROPIC_MODEL=claude-sonnet-4-6
PERPLEXITY_MODEL=sonar-pro
GOOGLE_MODEL=gemini-2.5-flash
XAI_MODEL=grok-4

# Web Search (per-provider, Perplexity always searches)
OPENAI_WEB_SEARCH=false
ANTHROPIC_WEB_SEARCH=false
GOOGLE_WEB_SEARCH=false

# Deep Research (model swap for supported providers)
GOOGLE_DEEP_RESEARCH=false
PERPLEXITY_DEEP_RESEARCH=false

# Google Custom Search API (for web search)
GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
GOOGLE_SEARCH_CX=your-custom-search-engine-id-here

# Optional: Settings
MAX_TOKENS=4000
TEMPERATURE=0.7
REQUEST_TIMEOUT=30

# Enable/disable providers
ENABLE_OPENAI=true
ENABLE_ANTHROPIC=true
ENABLE_PERPLEXITY=false
ENABLE_GOOGLE=true

# AI Analysis Settings (for run.py)
ANALYZE_RESPONSES=true
ANALYSIS_MODEL=gpt-5.2
ANALYSIS_CSV_PATH=analysis_results.csv

# Enhanced Analysis Settings (Optional - all default to false for backward compatibility)
ENABLE_ENHANCED_ANALYSIS=false
TRACK_HISTORY=false
DOMAIN_CLASSIFICATION=false
NEGATIVE_SIGNAL_DETECTION=false
ACCURACY_VERIFICATION=false
WEEKLY_REPORTING=false

# Enhanced Analysis Configuration
DATABASE_PATH=tracking.db
TARGET_COMPANY=Fisher Investments
COMPANY_DOMAINS=fisherinvestments.com,fishercareers.com
CORRECT_MINIMUM_INVESTMENT=$1,000,000

# Source Citation Settings
REQUEST_SOURCES=false
SOURCE_INSTRUCTION=Please cite your sources with specific URLs or domain names where this information can be verified.

# Frontend Auth Settings
AUTH_SECRET=change-me-to-your-team-password
JWT_SECRET=change-me-to-a-random-secret-string
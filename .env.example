# =============================================================================
# AI Multi-Query — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
#
# NOTE: Model selections, parameters (max tokens, temperature), web search /
# deep research toggles, and all AISEO settings are now configurable from the
# admin Settings panel and persisted to the database. Values here serve as
# initial defaults that seed the DB on first startup.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM API Keys (REQUIRED — at least one provider)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
PERPLEXITY_API_KEY=pplx-your-perplexity-key-here
GOOGLE_API_KEY=your-google-api-key-here
XAI_API_KEY=your-xai-api-key-here

# ---------------------------------------------------------------------------
# Model Defaults (override from Settings panel after first run)
# ---------------------------------------------------------------------------
OPENAI_MODEL=gpt-5.2
ANTHROPIC_MODEL=claude-sonnet-4-6
PERPLEXITY_MODEL=sonar-pro
GOOGLE_MODEL=gemini-2.5-flash
XAI_MODEL=grok-4

# ---------------------------------------------------------------------------
# Web Search (per-provider; Perplexity always searches)
# Override from Settings panel after first run.
# ---------------------------------------------------------------------------
OPENAI_WEB_SEARCH=false
ANTHROPIC_WEB_SEARCH=false
GOOGLE_WEB_SEARCH=false
XAI_WEB_SEARCH=false

# ---------------------------------------------------------------------------
# Deep Research (uses research-oriented model variant per provider)
# Override from Settings panel after first run.
# ---------------------------------------------------------------------------
OPENAI_DEEP_RESEARCH=false
ANTHROPIC_DEEP_RESEARCH=false
GOOGLE_DEEP_RESEARCH=false
PERPLEXITY_DEEP_RESEARCH=false
XAI_DEEP_RESEARCH=false

# ---------------------------------------------------------------------------
# Google Custom Search API (for the Google Search provider)
# ---------------------------------------------------------------------------
GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
GOOGLE_SEARCH_CX=your-custom-search-engine-id-here

# ---------------------------------------------------------------------------
# Query Parameters
# Override from Settings panel after first run.
# ---------------------------------------------------------------------------
MAX_TOKENS=8000
TEMPERATURE=0.7
REQUEST_TIMEOUT=30

# ---------------------------------------------------------------------------
# AI Analysis (for run.py CLI and AISEO pipeline)
# ---------------------------------------------------------------------------
ANALYZE_RESPONSES=false
ANALYSIS_MODEL=gpt-5.2
ANALYSIS_CSV_PATH=analysis_results.csv

# ---------------------------------------------------------------------------
# AISEO Company Config (initial seed values — manage from Settings panel)
# ---------------------------------------------------------------------------
# TARGET_COMPANY=Your Company Name
# COMPANY_DOMAINS=yourcompany.com,anotherdomain.com
# COMPANY_INDUSTRY=Your Industry
# COMPETITOR_DOMAINS=Competitor One:competitor1.com,Competitor Two:competitor2.com
# CORRECT_MINIMUM_INVESTMENT=$500,000

# AISEO Feature Toggles (all default to false; manage from Settings panel)
# ENABLE_ENHANCED_ANALYSIS=false
# TRACK_HISTORY=false
# DOMAIN_CLASSIFICATION=false
# NEGATIVE_SIGNAL_DETECTION=false
# ACCURACY_VERIFICATION=false
# WEEKLY_REPORTING=false

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-random-secret-string

# Initial Admin Account (seeded on first startup if no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-secure-password

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------
# Data persistence directory (databases, results, reports)
DATA_DIR=./data

# Public backend URL (set to your domain/IP in production)
NEXT_PUBLIC_API_URL=http://localhost:8000
